POSTGRES_USER=cloudlab
POSTGRES_PASSWORD=cloudlab_dev
POSTGRES_DB=cloudlab
DATABASE_URL=postgresql://cloudlab:cloudlab_dev@db:5432/cloudlab
PORT=3000
NODE_ENV=development

# Keycloak
KC_BOOTSTRAP_ADMIN_USERNAME=admin
